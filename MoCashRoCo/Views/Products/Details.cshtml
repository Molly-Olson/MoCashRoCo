@model MoCashRoCo.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var related = ViewBag.Related as List<MoCashRoCo.Models.Product> ?? new();
}

<!-- Breadcrumb -->
<div class="bg-light border-bottom py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index" class="text-decoration-none">Shop</a></li>
                @if (Model.Category != null)
                {
                    <li class="breadcrumb-item">
                        <a asp-controller="Products" asp-action="Index" asp-route-category="@Model.CategoryId"
                           class="text-decoration-none">@Model.Category.Name</a>
                    </li>
                }
                <li class="breadcrumb-item active fw-semibold">@Model.Name</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
            <i class="bi bi-check-circle-fill text-success"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-5">
        <!-- Image -->
        <div class="col-md-6">
            <div class="rounded-3 overflow-hidden shadow">
                <img src="@(Model.ImageUrl ?? "https://picsum.photos/seed/default/600/400")"
                     class="img-fluid w-100" style="max-height:480px;object-fit:cover" alt="@Model.Name" />
            </div>
            <div class="d-flex gap-2 mt-3">
                @for (int i = 0; i < 3; i++)
                {
                    <img src="@(Model.ImageUrl ?? "https://picsum.photos/seed/default/600/400")"
                         class="rounded border @(i == 0 ? "border-brand border-2" : "") cursor-pointer"
                         style="width:72px;height:72px;object-fit:cover" alt="View @(i+1)" />
                }
            </div>
        </div>

        <!-- Details -->
        <div class="col-md-6">
            <span class="badge bg-brand-soft text-brand mb-2">@Model.Category?.Name</span>
            <h1 class="fw-bold h2 mb-3">@Model.Name</h1>

            <div class="d-flex align-items-center gap-3 mb-3">
                <span class="display-6 fw-bold text-brand">$@Model.Price.ToString("F2")</span>
                @if (Model.StockQuantity > 10)
                {
                    <span class="badge bg-success-subtle text-success px-3 py-2">
                        <i class="bi bi-check-circle me-1"></i>In Stock
                    </span>
                }
                else if (Model.StockQuantity > 0)
                {
                    <span class="badge bg-warning-subtle text-warning px-3 py-2">
                        <i class="bi bi-exclamation-circle me-1"></i>Only @Model.StockQuantity left
                    </span>
                }
                else
                {
                    <span class="badge bg-danger-subtle text-danger px-3 py-2">
                        <i class="bi bi-x-circle me-1"></i>Out of Stock
                    </span>
                }
            </div>

            <!-- Rating (mock) -->
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="text-warning">
                    <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                    <i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                </div>
                <span class="text-muted small">4.5 (128 reviews)</span>
            </div>

            <p class="text-muted lh-lg mb-4">@Model.Description</p>

            <form asp-controller="Cart" asp-action="Add" method="post">
                <input type="hidden" name="productId" value="@Model.ProductId" />
                <div class="d-flex align-items-center gap-3 mb-4">
                    <label class="fw-semibold">Quantity:</label>
                    <div class="input-group" style="width:120px">
                        <button type="button" class="btn btn-outline-secondary" onclick="adjustQty(-1)">−</button>
                        <input type="number" id="qtyInput" name="quantity" value="1" min="1"
                               max="@Model.StockQuantity" class="form-control text-center" />
                        <button type="button" class="btn btn-outline-secondary" onclick="adjustQty(1)">+</button>
                    </div>
                </div>
                <div class="d-flex gap-3 mb-4">
                    <button type="submit" class="btn btn-brand btn-lg flex-grow-1 rounded-pill"
                            @(Model.StockQuantity == 0 ? "disabled" : "")>
                        <i class="bi bi-cart-plus me-2"></i>Add to Cart
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-lg rounded-pill px-3" title="Save for later">
                        <i class="bi bi-heart"></i>
                    </button>
                </div>
            </form>

            <!-- Perks -->
            <div class="border rounded-3 p-3 bg-light">
                <div class="row g-2 text-muted small">
                    <div class="col-6 d-flex align-items-center gap-2">
                        <i class="bi bi-truck text-brand fs-5"></i>
                        <span>Free shipping over $50</span>
                    </div>
                    <div class="col-6 d-flex align-items-center gap-2">
                        <i class="bi bi-shield-check text-brand fs-5"></i>
                        <span>Secure checkout</span>
                    </div>
                    <div class="col-6 d-flex align-items-center gap-2">
                        <i class="bi bi-arrow-return-left text-brand fs-5"></i>
                        <span>30-day returns</span>
                    </div>
                    <div class="col-6 d-flex align-items-center gap-2">
                        <i class="bi bi-headset text-brand fs-5"></i>
                        <span>24/7 support</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (related.Any())
    {
        <div class="mt-5 pt-4 border-top">
            <h4 class="fw-bold mb-4">Related Products</h4>
            <div class="row row-cols-2 row-cols-md-4 g-4">
                @foreach (var p in related)
                {
                    <div class="col">
                        <div class="card product-card h-100 border-0 shadow-sm">
                            <div style="overflow:hidden">
                                <a asp-action="Details" asp-route-id="@p.ProductId">
                                    <img src="@(p.ImageUrl ?? "https://picsum.photos/seed/default/600/400")"
                                         class="card-img-top product-img" alt="@p.Name" style="height:160px" />
                                </a>
                            </div>
                            <div class="card-body p-3">
                                <h6 class="fw-semibold small mb-1 line-clamp-2">@p.Name</h6>
                                <span class="fw-bold text-brand">$@p.Price.ToString("F2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function adjustQty(delta) {
            const input = document.getElementById('qtyInput');
            const min = parseInt(input.min) || 1;
            const max = parseInt(input.max) || 999;
            input.value = Math.min(max, Math.max(min, parseInt(input.value || 1) + delta));
        }
    </script>
}
