@model List<MoCashRoCo.Models.Product>
@{
    ViewData["Title"] = "Shop";
    var categories = ViewBag.Categories as List<MoCashRoCo.Models.Category> ?? new();
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var search = ViewBag.Search as string ?? "";
    var sort = ViewBag.Sort as string ?? "";

    string SortUrl(string s) =>
        $"?sort={s}" +
        (selectedCategory.HasValue ? $"&category={selectedCategory}" : "") +
        (!string.IsNullOrEmpty(search) ? $"&search={Uri.EscapeDataString(search)}" : "");
}

<!-- Breadcrumb -->
<div class="bg-light border-bottom py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item active fw-semibold">Shop</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill text-success"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-3 mb-3">
                <div class="card-body p-3">
                    <h6 class="fw-bold text-uppercase text-muted small mb-2" style="letter-spacing:.08em">Search</h6>
                    <form method="get">
                        @if (selectedCategory.HasValue)
                        {
                            <input type="hidden" name="category" value="@selectedCategory" />
                        }
                        @if (!string.IsNullOrEmpty(sort))
                        {
                            <input type="hidden" name="sort" value="@sort" />
                        }
                        <div class="input-group">
                            <input type="text" name="search" class="form-control form-control-sm"
                                   placeholder="Search products..." value="@search" />
                            <button class="btn btn-brand btn-sm" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-3">
                    <h6 class="fw-bold text-uppercase text-muted small mb-3" style="letter-spacing:.08em">Categories</h6>
                    <div class="list-group list-group-flush">
                        <a asp-action="Index" asp-route-search="@(search)" asp-route-sort="@sort"
                           class="list-group-item list-group-item-action border-0 rounded mb-1 px-3 py-2 small @(selectedCategory == null ? "active-filter" : "")">
                            <i class="bi bi-grid me-2"></i>All Products
                            <span class="badge bg-secondary float-end">@Model.Count</span>
                        </a>
                        @foreach (var cat in categories)
                        {
                            <a asp-action="Index" asp-route-category="@cat.CategoryId"
                               asp-route-search="@(search)" asp-route-sort="@sort"
                               class="list-group-item list-group-item-action border-0 rounded mb-1 px-3 py-2 small @(selectedCategory == cat.CategoryId ? "active-filter" : "")">
                                <i class="bi bi-tag me-2"></i>@cat.Name
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Grid -->
        <div class="col-lg-9">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                <h5 class="mb-0 fw-bold">
                    @if (selectedCategory.HasValue)
                    {
                        @(categories.FirstOrDefault(c => c.CategoryId == selectedCategory)?.Name ?? "Products")
                    }
                    else if (!string.IsNullOrEmpty(search))
                    {
                        <text>Results for "@search"</text>
                    }
                    else
                    {
                        <text>All Products</text>
                    }
                    <span class="text-muted fw-normal fs-6 ms-2">(@Model.Count)</span>
                </h5>
                <div class="d-flex gap-2 align-items-center">
                    <label class="text-muted small me-1">Sort:</label>
                    <a href="@SortUrl("name")" class="btn btn-sm @(sort is "" or "name" ? "btn-brand" : "btn-outline-secondary")">A–Z</a>
                    <a href="@SortUrl("price-asc")" class="btn btn-sm @(sort == "price-asc" ? "btn-brand" : "btn-outline-secondary")">
                        <i class="bi bi-sort-numeric-up"></i>
                    </a>
                    <a href="@SortUrl("price-desc")" class="btn btn-sm @(sort == "price-desc" ? "btn-brand" : "btn-outline-secondary")">
                        <i class="bi bi-sort-numeric-down"></i>
                    </a>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-light rounded-3">
                    <i class="bi bi-search display-3 text-muted d-block mb-3"></i>
                    <h5 class="text-muted">No products found</h5>
                    <p class="text-muted small">Try adjusting your search or clearing the filters.</p>
                    <a asp-action="Index" class="btn btn-brand rounded-pill px-4 mt-2">Clear Filters</a>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-4">
                    @foreach (var product in Model)
                    {
                        <div class="col">
                            <div class="card product-card h-100 border-0 shadow-sm">
                                <div style="overflow:hidden">
                                    <a asp-action="Details" asp-route-id="@product.ProductId">
                                        <img src="@(product.ImageUrl ?? "https://picsum.photos/seed/default/600/400")"
                                             class="card-img-top product-img" alt="@product.Name" />
                                    </a>
                                </div>
                                <div class="card-body d-flex flex-column p-3">
                                    <span class="badge bg-brand-soft text-brand mb-2 align-self-start small">@product.Category?.Name</span>
                                    <h6 class="card-title fw-semibold mb-1 line-clamp-2">
                                        <a asp-action="Details" asp-route-id="@product.ProductId"
                                           class="text-dark text-decoration-none">@product.Name</a>
                                    </h6>
                                    <p class="card-text text-muted small mb-3 flex-grow-1 line-clamp-2">@product.Description</p>
                                    <div class="d-flex align-items-center justify-content-between mt-auto">
                                        <span class="fs-5 fw-bold text-brand">$@product.Price.ToString("F2")</span>
                                        <div class="d-flex gap-1">
                                            <a asp-action="Details" asp-route-id="@product.ProductId"
                                               class="btn btn-outline-secondary btn-sm" title="View details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                                <input type="hidden" name="productId" value="@product.ProductId" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <button type="submit" class="btn btn-brand btn-sm" title="Add to cart">
                                                    <i class="bi bi-cart-plus"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
