@{
    ViewData["Title"] = "Home";
    var featured = ViewBag.Featured as List<MoCashRoCo.Models.Product> ?? new();
    var categories = ViewBag.Categories as List<MoCashRoCo.Models.Category> ?? new();
    var catIcons = new Dictionary<string, string>
    {
        {"Electronics","bi-cpu-fill"},
        {"Clothing","bi-bag-fill"},
        {"Home & Kitchen","bi-house-fill"},
        {"Sports & Outdoors","bi-trophy-fill"},
        {"Books & Media","bi-book-fill"}
    };
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-0 rounded-0 text-center py-2" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Hero -->
<section class="hero-section">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-7" style="position:relative;z-index:1">
                <span class="badge bg-accent px-3 py-2 mb-3 rounded-pill text-uppercase fw-semibold" style="letter-spacing:.08em">
                    <i class="bi bi-stars me-1"></i>New Arrivals
                </span>
                <h1 class="display-4 fw-bold text-white mb-4 lh-sm">
                    Quality You Can<br><span style="color:var(--accent)">Count On.</span>
                </h1>
                <p class="lead text-white mb-4" style="opacity:.80">
                    Discover premium products curated for every lifestyle — from tech to fashion, home to outdoors.
                </p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-accent btn-lg px-5 rounded-pill shadow">
                        Shop Now <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <a asp-controller="Home" asp-action="About" class="btn btn-outline-light btn-lg px-5 rounded-pill">
                        Learn More
                    </a>
                </div>
                <div class="d-flex flex-wrap gap-4 text-white small" style="opacity:.75">
                    <span><i class="bi bi-truck me-1"></i>Free shipping over $50</span>
                    <span><i class="bi bi-shield-check me-1"></i>Secure checkout</span>
                    <span><i class="bi bi-arrow-return-left me-1"></i>30-day returns</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Value Props -->
<section class="py-4 bg-white border-bottom">
    <div class="container">
        <div class="row row-cols-2 row-cols-md-4 g-3 text-center">
            @{
                var props = new[] {
                    ("bi-truck","Free Shipping","On orders over $50"),
                    ("bi-shield-check","Secure Payments","SSL encrypted checkout"),
                    ("bi-arrow-return-left","Easy Returns","30-day return policy"),
                    ("bi-headset","24/7 Support","Always here to help")
                };
            }
            @foreach (var (icon, title, sub) in props)
            {
                <div class="col value-prop-section">
                    <div class="py-3">
                        <i class="bi @icon fs-3 text-brand mb-2 d-block"></i>
                        <h6 class="fw-bold mb-0">@title</h6>
                        <small class="text-muted">@sub</small>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Shop by Category -->
@if (categories.Any())
{
    <section class="py-5 bg-light">
        <div class="container">
            <div class="text-center mb-4">
                <h2 class="fw-bold">Shop by Category</h2>
                <p class="text-muted">Find exactly what you're looking for</p>
            </div>
            <div class="row row-cols-2 row-cols-md-5 g-3">
                @foreach (var cat in categories)
                {
                    var icon = catIcons.GetValueOrDefault(cat.Name, "bi-tag-fill");
                    <div class="col">
                        <a asp-controller="Products" asp-action="Index" asp-route-category="@cat.CategoryId"
                           class="card category-card border-0 shadow-sm text-center text-decoration-none h-100">
                            <div class="card-body py-4">
                                <i class="bi @icon fs-1 text-brand mb-2 d-block" style="transition:all .2s"></i>
                                <h6 class="fw-semibold text-dark mb-0 small">@cat.Name</h6>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Featured Products -->
@if (featured.Any())
{
    <section class="py-5">
        <div class="container">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Featured Products</h2>
                    <p class="text-muted mb-0">Handpicked favorites from our collection</p>
                </div>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-brand rounded-pill px-4">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
                @foreach (var product in featured)
                {
                    <div class="col">
                        <div class="card product-card h-100 border-0 shadow-sm">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">
                                <img src="@(product.ImageUrl ?? "https://picsum.photos/seed/default/600/400")"
                                     class="card-img-top product-img" alt="@product.Name" />
                            </a>
                            <div class="card-body d-flex flex-column p-3">
                                <span class="badge bg-brand-soft text-brand mb-2 align-self-start small">@product.Category?.Name</span>
                                <h6 class="fw-semibold mb-1 line-clamp-2">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId"
                                       class="text-dark text-decoration-none">@product.Name</a>
                                </h6>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                                    <span class="fs-5 fw-bold text-brand">$@product.Price.ToString("F2")</span>
                                    <form asp-controller="Cart" asp-action="Add" method="post">
                                        <input type="hidden" name="productId" value="@product.ProductId" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-brand btn-sm rounded-pill px-3">
                                            <i class="bi bi-cart-plus me-1"></i>Add
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- CTA Banner -->
<section class="bg-brand py-5">
    <div class="container text-center text-white">
        <h2 class="fw-bold mb-2">Ready to find your next favorite?</h2>
        <p class="mb-4" style="opacity:.80">Browse our full catalog of premium products, all backed by our quality guarantee.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-accent btn-lg px-5 rounded-pill shadow">
            Explore All Products <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>
</section>
