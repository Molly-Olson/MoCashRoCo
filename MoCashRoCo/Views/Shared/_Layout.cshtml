<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MoCashRo Web Co.</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MoCashRoCo.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var cartCount = 0;
        var cartStr = ViewContext.HttpContext.Session.GetString("CartItemCount");
        int.TryParse(cartStr, out cartCount);
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <nav class="navbar navbar-expand-lg navbar-dark bg-brand sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-5" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shop-window me-2"></i>MoCashRo<span class="text-accent">Web</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-2">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active text-white" : "")"
                           asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Products" ? "active text-white" : "")"
                           asp-controller="Products" asp-action="Index">Shop</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "About" ? "active text-white" : "")"
                           asp-controller="Home" asp-action="About">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "Contact" ? "active text-white" : "")"
                           asp-controller="Home" asp-action="Contact">Contact</a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Cart" asp-action="Index"
                       class="btn btn-outline-light btn-sm px-3 position-relative">
                        <i class="bi bi-cart3 me-1"></i>Cart
                        @if (cartCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-accent" style="font-size:.65rem">
                                @cartCount
                            </span>
                        }
                    </a>
                    <a href="#" class="btn btn-accent btn-sm px-3">
                        <i class="bi bi-person me-1"></i>Sign In
                    </a>
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="bg-dark text-light pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold text-white mb-3">
                        <i class="bi bi-shop-window me-2 text-accent"></i>MoCashRo<span style="color:var(--accent)">Web</span>
                    </h5>
                    <p class="text-secondary small lh-lg">Quality you can count on. Your trusted online marketplace for premium products across every category.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-secondary fs-5 text-decoration-none"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-secondary fs-5 text-decoration-none"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-secondary fs-5 text-decoration-none"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-secondary fs-5 text-decoration-none"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="fw-semibold text-white mb-3">Shop</h6>
                    <ul class="list-unstyled mb-0">
                        <li><a asp-controller="Products" asp-action="Index" class="text-secondary text-decoration-none footer-link">All Products</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-category="1" class="text-secondary text-decoration-none footer-link">Electronics</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-category="2" class="text-secondary text-decoration-none footer-link">Clothing</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-category="3" class="text-secondary text-decoration-none footer-link">Home &amp; Kitchen</a></li>
                        <li><a asp-controller="Products" asp-action="Index" asp-route-category="4" class="text-secondary text-decoration-none footer-link">Sports</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6">
                    <h6 class="fw-semibold text-white mb-3">Company</h6>
                    <ul class="list-unstyled mb-0">
                        <li><a asp-controller="Home" asp-action="About" class="text-secondary text-decoration-none footer-link">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Contact" class="text-secondary text-decoration-none footer-link">Contact</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy" class="text-secondary text-decoration-none footer-link">Privacy Policy</a></li>
                        <li><a href="#" class="text-secondary text-decoration-none footer-link">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="fw-semibold text-white mb-3">Stay Updated</h6>
                    <p class="text-secondary small">Get deals, new arrivals, and exclusive offers delivered to your inbox.</p>
                    <div class="input-group">
                        <input type="email" class="form-control form-control-sm" placeholder="your@email.com" />
                        <button class="btn btn-accent btn-sm px-3">Subscribe</button>
                    </div>
                    <div class="d-flex gap-2 mt-3 flex-wrap">
                        <span class="badge bg-secondary"><i class="bi bi-shield-check me-1"></i>Secure</span>
                        <span class="badge bg-secondary"><i class="bi bi-truck me-1"></i>Free Shipping</span>
                        <span class="badge bg-secondary"><i class="bi bi-arrow-return-left me-1"></i>30-Day Returns</span>
                    </div>
                </div>
            </div>
            <hr class="border-secondary opacity-25" />
            <div class="d-flex flex-wrap justify-content-between align-items-center">
                <p class="text-secondary small mb-0">&copy; 2026 MoCashRo Web Co. All rights reserved.</p>
                <p class="text-secondary small mb-0">Built with ASP.NET Core MVC &amp; Bootstrap 5</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
