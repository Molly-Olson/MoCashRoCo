@model List<MoCashRoCo.Models.CartItem>
@{
    ViewData["Title"] = "Your Cart";
    var subtotal = Model.Sum(i => i.LineTotal);
    var shipping = subtotal >= 50 ? 0m : 5.99m;
    var total = subtotal + shipping;
}

<!-- Breadcrumb -->
<div class="bg-light border-bottom py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item active fw-semibold">Cart</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container my-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2 text-brand"></i>Your Cart</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="bg-brand-soft rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width:100px;height:100px">
                <i class="bi bi-cart-x fs-1 text-brand"></i>
            </div>
            <h4 class="fw-bold text-muted mb-2">Your cart is empty</h4>
            <p class="text-muted mb-4">Looks like you haven't added anything yet. Let's change that!</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-brand btn-lg px-5 rounded-pill">
                <i class="bi bi-bag me-2"></i>Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Items -->
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="card border-0 shadow-sm rounded-3 mb-3">
                        <div class="card-body p-3">
                            <div class="row align-items-center g-3">
                                <div class="col-auto">
                                    <img src="@(item.ImageUrl ?? "https://picsum.photos/seed/default/80/80")"
                                         class="rounded-2" style="width:80px;height:80px;object-fit:cover" alt="@item.Name" />
                                </div>
                                <div class="col">
                                    <h6 class="fw-semibold mb-1">@item.Name</h6>
                                    <span class="text-muted small">$@item.Price.ToString("F2") each</span>
                                </div>
                                <div class="col-auto text-end">
                                    <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="mb-2">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <div class="input-group input-group-sm" style="width:110px">
                                            <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                    class="btn btn-outline-secondary">−</button>
                                            <span class="input-group-text bg-white fw-semibold">@item.Quantity</span>
                                            <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                    class="btn btn-outline-secondary">+</button>
                                        </div>
                                    </form>
                                    <div class="d-flex align-items-center justify-content-end gap-3">
                                        <span class="fw-bold text-brand">$@item.LineTotal.ToString("F2")</span>
                                        <form asp-controller="Cart" asp-action="Remove" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-link text-danger p-0" title="Remove">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left me-2"></i>Continue Shopping
                    </a>
                    <form asp-controller="Cart" asp-action="Clear" method="post">
                        <button type="submit" class="btn btn-link text-muted small text-decoration-none">
                            <i class="bi bi-x-circle me-1"></i>Clear Cart
                        </button>
                    </form>
                </div>
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal (@Model.Sum(i => i.Quantity) items)</span>
                            <span>$@subtotal.ToString("F2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Shipping</span>
                            @if (shipping == 0)
                            {
                                <span class="text-success fw-semibold">Free</span>
                            }
                            else
                            {
                                <span>$@shipping.ToString("F2")</span>
                            }
                        </div>
                        @if (shipping > 0)
                        {
                            <div class="alert alert-light border small py-2 mt-2 mb-2">
                                <i class="bi bi-info-circle text-brand me-1"></i>
                                Add $@((50 - subtotal).ToString("F2")) more for free shipping!
                            </div>
                        }
                        <hr class="my-3" />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Total</span>
                            <span class="text-brand">$@total.ToString("F2")</span>
                        </div>
                        <button class="btn btn-brand btn-lg w-100 rounded-pill mb-3">
                            <i class="bi bi-lock me-2"></i>Proceed to Checkout
                        </button>
                        <div class="d-flex justify-content-center gap-3 text-muted small">
                            <span><i class="bi bi-shield-lock me-1"></i>Secure</span>
                            <span><i class="bi bi-credit-card me-1"></i>All major cards</span>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <h6 class="fw-semibold mb-2">Promo Code</h6>
                        <div class="input-group">
                            <input type="text" class="form-control form-control-sm" placeholder="Enter promo code..." />
                            <button class="btn btn-outline-brand btn-sm">Apply</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
